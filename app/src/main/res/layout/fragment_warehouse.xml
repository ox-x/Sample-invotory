<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page"
    android:padding="@dimen/sp_sm">

    <!-- ============ 搜索与概览统计卡片 ============ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sp_sm"
        app:cardElevation="2dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/module_warehouse_light">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/sp_md">

            <!-- Search Bar -->
            <EditText
                android:id="@+id/etWhSearch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input_rounded"
                android:hint="@string/wh_search_hint"
                android:inputType="text"
                android:minHeight="40dp"
                android:paddingStart="@dimen/sp_md"
                android:paddingEnd="@dimen/sp_md"
                android:singleLine="true"
                android:textSize="13sp" />

            <!-- Overview Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/sp_md"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/warehouse_overview"
                    android:textColor="@color/module_warehouse"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <!-- Row 1: Items | Boxes | Contents | Standalone -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvWhStatItems"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvWhStatBoxes"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvWhStatContents"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_primary"
                        android:textSize="12sp" />

                    <TextView
                        android:id="@+id/tvWhStatStandalone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="2dp"
                    android:background="@color/bg_divider" />

                <!-- Row 2: In Stock | Borrowed -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvWhStatInStock"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/module_stockin"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvWhStatBorrowed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/module_checkout"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ============ 导出按钮 ============ -->
    <Button
        android:id="@+id/btnWhExport"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:layout_marginBottom="@dimen/sp_sm"
        android:background="@drawable/bg_btn_warehouse_primary"
        android:text="@string/wh_export"
        android:textColor="@color/white"
        android:textSize="13sp"
        android:textStyle="bold" />

    <!-- ============ 筛选与视图切换卡片 ============ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/sp_sm"
        app:cardElevation="2dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/module_warehouse_light">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="@dimen/sp_sm">

            <Button
                android:id="@+id/btnWhFilterAll"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_warehouse_primary"
                android:text="@string/wh_filter_all"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnWhFilterInStock"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/sp_md"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_warehouse_gray"
                android:text="@string/wh_filter_in_stock"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnWhFilterBorrowed"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/sp_md"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_warehouse_gray"
                android:text="@string/wh_filter_borrowed"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnWhViewToggle"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="@dimen/sp_md"
                android:layout_weight="1"
                android:background="@drawable/bg_btn_warehouse_primary"
                android:text="@string/wh_view_grid"
                android:textColor="@color/white"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- ============ 内容区域卡片 ============ -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardElevation="2dp"
        app:cardCornerRadius="16dp"
        app:cardBackgroundColor="@color/module_warehouse_light">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- List View (ExpandableListView with collapsible groups) -->
            <ExpandableListView
                android:id="@+id/elvWhList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@android:color/transparent"
                android:dividerHeight="@dimen/sp_md"
                android:childDivider="@android:color/transparent"
                android:groupIndicator="@null"
                android:visibility="visible" />

            <!-- Empty text for list view -->
            <TextView
                android:id="@+id/tvWhEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="@dimen/sp_xxxl"
                android:text="@string/wh_no_results"
                android:textColor="@color/text_hint"
                android:textSize="13sp"
                android:visibility="gone" />

            <!-- Grid View (RecyclerView with GridLayoutManager) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvWhGridView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" />

            <!-- Empty text for grid view -->
            <TextView
                android:id="@+id/tvWhGridEmpty"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:padding="@dimen/sp_xxxl"
                android:text="@string/wh_no_results"
                android:textColor="@color/text_hint"
                android:textSize="13sp"
                android:visibility="gone" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
