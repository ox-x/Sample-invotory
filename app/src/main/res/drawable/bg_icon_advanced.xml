<?xml version="1.0" encoding="utf-8"?>
<!--
    高级选项图标 - 毛玻璃质感背景
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 阴影层 -->
    <item
        android:left="0dp"
        android:top="2dp"
        android:right="2dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#26000000" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- 毛玻璃基底 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#B3FFFFFF" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- 主题色微染：深灰 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#1A37474F" />
            <corners android:radius="16dp" />
        </shape>
    </item>

    <!-- 玻璃高光反射 -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#99FFFFFF"
                android:endColor="#00FFFFFF"
                android:angle="135" />
            <corners android:radius="16dp" />
        </shape>
    </item>
</layer-list>
